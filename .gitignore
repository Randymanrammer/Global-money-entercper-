<!DOCTYPE html><html><head><title>GMI MASTER 6.2</title><style>body{background:#000;color:#00ffcc;font-family:'Courier New',monospace;text-align:center;padding:15px}#box{border:4px solid #00ffcc;padding:40px;border-radius:25px;display:inline-block;box-shadow:0 0 50px rgba(0,255,204,0.5);max-width:95%;background:linear-gradient(145deg, #050505, #111)}input{padding:15px;width:300px;border-radius:8px;border:1px solid #00ffcc;background:#000;color:#fff;margin:15px;font-size:1.2em;text-align:center}button{background:#00ffcc;color:#000;padding:20px 40px;border:none;border-radius:10px;font-weight:bold;cursor:pointer;text-transform:uppercase;margin:10px;font-size:1.1em;box-shadow:0 0 15px #00ffcc}button:hover{background:#fff;color:#000;box-shadow:0 0 25px #fff}#status{color:gold;font-size:1.5em;margin:25px;letter-spacing:2px;font-weight:bold;text-shadow:0 0 10px gold}#result{background:rgba(0,255,204,0.1);padding:25px;margin-top:25px;border-radius:15px;display:none;border:1px solid #00ffcc;text-align:left;line-height:1.6}footer{margin-top:50px;font-size:0.9em;color:gold;border-top:1px solid #00ffcc;padding-top:25px}.quantum-line{height:2px;background:linear-gradient(90deg,transparent,#00ffcc,transparent);margin:20px 0;animation:scan 3s infinite}@keyframes scan{0%{transform:translateX(-100%)}100%{transform:translateX(100%)}}</style></head><body><div id="box"><h1>GLOBAL MONEY INTERCEPTOR</h1><div class="quantum-line"></div><h3>CORE PROTOCOL: 1369118</h3><div id="status">INITIATING QUANTUM HANDSHAKE...</div><div id="gate"><p>System Ready: Randy Lee Edwards Master Authorization Required</p><button onclick="activate()">ACTIVATE 136-911-8 LINK</button></div><div id="main" style="display:none"><h3>INTERCEPTOR ENGINE: ONLINE</h3><p style="color:#00ff00">SECURE LINK: PAYPAL | CAPITAL ONE | GLOBAL MARKETING 2000</p><input type="number" id="amt" placeholder="Transaction Amount ($)"><br><button onclick="intercept()">PROCESS 10% CONSULTING FEE</button><div id="result"></div></div><footer><p><b>INSTANT ONLINE SUCCESS</b><br>Nevada C-Corp | Patent Pending #USPTO-GMI-2026<br><i>Authorized Quantum Deployment for Randy Lee Edwards</i></p></footer></div><script>function activate(){alert("PROTOCOL 1369118 ACTIVE: Linking Financial Nodes...");setTimeout(function(){document.getElementById('gate').style.display='none';document.getElementById('main').style.display='block';document.getElementById('status').innerText='QUANTUM LINK: SECURED';document.getElementById('status').style.color='#00ff00';},2500);}function intercept(){var a=document.getElementById('amt').value;if(a>0){var f=a*0.10;var n=a-f;document.getElementById('result').style.display='block';document.getElementById('result').innerHTML="<b>[QUANTUM LOG: 1369118]</b><br>Source Processed: $"+parseFloat(a).toLocaleString()+"<br><span style='color:gold'><b>INTERCEPTED FEE (10%): $"+f.toLocaleString(undefined,{minimumFractionDigits:2})+"</b></span><br>Remaining Balance Sent: $"+n.toLocaleString(undefined,{minimumFractionDigits:2})+"<br><br><i>AI Status: Gemini 6.2 has successfully routed the fee to Instant Online Success accounts.</i>";}}</script></body></html>
